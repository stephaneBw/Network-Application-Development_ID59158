<?xml version="1.0" encoding="utf-8" ?>
<configuration>
    <startup> 
        <supportedRuntime version="v4.0" sku=".NETFramework,Version=v4.8" />
    </startup>
    <system.serviceModel>
        <bindings>
            <basicHttpBinding>
                <binding name="BasicHttpBinding_IExchangeOfficeService" />
            </basicHttpBinding>
        </bindings>
        <!-- If WCF connection fails: run ExchangeOffice.Service (F5), copy .svc URL from browser, update address below -->
        <client>
            <endpoint address="http://localhost:60456/ExchangeOfficeService.svc"
                binding="basicHttpBinding" bindingConfiguration="BasicHttpBinding_IExchangeOfficeService"
                contract="ExchangeOfficeRef.IExchangeOfficeService" name="BasicHttpBinding_IExchangeOfficeService" />
        </client>
    </system.serviceModel>
</configuration>