<Window x:Class="ExchangeOffice.Client.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Currency Exchange Office — Network Application Development" Height="620" Width="720" WindowStartupLocation="CenterScreen">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TabControl Grid.Row="0" Margin="10">
            <TabItem Header="1. Account Registration">
                <StackPanel Margin="15">
                    <TextBlock Text="Create New Account" FontSize="14" FontWeight="Bold" Foreground="#2196F3" Margin="0,0,0,10"/>
                    <TextBlock Text="Username:" Margin="0,5,0,0"/>
                    <TextBox x:Name="UsernameTextBox" Margin="0,5,0,0" Padding="4"/>
                    <TextBlock Text="Password:" Margin="0,10,0,0"/>
                    <PasswordBox x:Name="PasswordBox" Margin="0,5,0,15" Padding="4"/>
                    <Button Content="Register Account" Height="30" FontWeight="Bold" Background="#2196F3" Foreground="White" Click="RegisterButton_Click"/>
                </StackPanel>
            </TabItem>

            <TabItem Header="2. Market Rates">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="15">
                        <TextBlock Text="Live NBP Marketplace Query" FontSize="14" FontWeight="Bold" Foreground="#4CAF50" Margin="0,0,0,10"/>
                        <TextBlock Text="Currency Code (e.g., USD, EUR, GBP):" Margin="0,5,0,0"/>
                        <TextBox x:Name="CurrencyTextBox" Margin="0,5,0,15" Text="USD" Padding="4"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Button Content="Get Current Rate" Width="140" Height="30" Click="GetRateButton_Click"/>
                            <TextBlock x:Name="RateTextBlock" Grid.Column="1" Margin="15,0,0,0" FontSize="14" FontWeight="Bold" VerticalAlignment="Center" Foreground="#4CAF50"/>
                        </Grid>

                        <Separator Margin="0,20,0,15"/>

                        <TextBlock Text="Historical Rates Report (Lab 13)" FontSize="14" FontWeight="Bold" Foreground="#009688" Margin="0,0,0,10"/>
                        <TextBlock Text="Currency Code:" Margin="0,5,0,0"/>
                        <TextBox x:Name="HistoricalCurrencyTextBox" Text="USD" Margin="0,5,0,10" Padding="4"/>

                        <Grid Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Margin="0,0,8,0">
                                <TextBlock Text="From date:"/>
                                <DatePicker x:Name="HistoryFromDatePicker" Margin="0,5,0,0"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1" Margin="8,0,0,0">
                                <TextBlock Text="To date:"/>
                                <DatePicker x:Name="HistoryToDatePicker" Margin="0,5,0,0"/>
                            </StackPanel>
                        </Grid>

                        <Button Content="Load Historical Rates" Width="180" Height="30" Background="#009688" Foreground="White" FontWeight="SemiBold" Click="GetHistoricalRatesButton_Click" Margin="0,0,0,10"/>

                        <DataGrid x:Name="HistoricalRatesDataGrid"
                                  AutoGenerateColumns="False"
                                  IsReadOnly="True"
                                  CanUserAddRows="False"
                                  CanUserDeleteRows="False"
                                  HeadersVisibility="Column"
                                  Height="220">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Date" Binding="{Binding Date, StringFormat=yyyy-MM-dd}" Width="120"/>
                                <DataGridTextColumn Header="Mid Rate (PLN)" Binding="{Binding Rate, StringFormat=N4}" Width="*"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <TabItem Header="3. Trading Desk">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="15">
                        <TextBlock Text="Execute Exchange Transactions" FontSize="14" FontWeight="Bold" Foreground="#FF9800" Margin="0,0,0,10"/>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Margin="0,0,10,0">
                                <TextBlock Text="Top-up PLN Amount:"/>
                                <TextBox x:Name="TopUpTextBox" Text="1000" Margin="0,5,0,0" Padding="4"/>
                            </StackPanel>
                            <Button x:Name="TopUpButton" Content="Deposit PLN" Grid.Column="1" Width="120" Height="28" VerticalAlignment="Bottom" Background="#FF9800" Foreground="White" FontWeight="SemiBold" IsEnabled="False" Click="TopUpButton_Click"/>
                        </Grid>

                        <Separator Margin="0,15,0,15"/>

                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,5,10">
                                <TextBlock Text="Trading Currency:"/>
                                <TextBox x:Name="TradeCurrencyTextBox" Text="USD" Margin="0,5,0,0" Padding="4"/>
                            </StackPanel>

                            <StackPanel Grid.Row="0" Grid.Column="1" Margin="5,0,0,10">
                                <TextBlock Text="Foreign Quantity:"/>
                                <TextBox x:Name="TradeAmountTextBox" Text="100" Margin="0,5,0,0" Padding="4"/>
                            </StackPanel>

                            <Button x:Name="BuyButton" Content="Buy Currency" Grid.Row="1" Grid.Column="0" Height="30" Margin="0,0,5,0" Background="#4CAF50" Foreground="White" FontWeight="Bold" IsEnabled="False" Click="BuyButton_Click"/>
                            <Button x:Name="SellButton" Content="Sell Currency" Grid.Row="1" Grid.Column="1" Height="30" Margin="5,0,0,0" Background="#F44336" Foreground="White" FontWeight="Bold" IsEnabled="False" Click="SellButton_Click"/>
                        </Grid>

                        <Separator Margin="0,15,0,15"/>

                        <TextBlock Text="Transaction History (Lab 12)" FontSize="13" FontWeight="Bold" Foreground="#607D8B" Margin="0,0,0,8"/>
                        <Button x:Name="RefreshHistoryButton" Content="Refresh History" Height="28" Width="140" HorizontalAlignment="Left" IsEnabled="False" Click="RefreshHistoryButton_Click" Margin="0,0,0,8"/>

                        <DataGrid x:Name="HistoryDataGrid"
                                  AutoGenerateColumns="False"
                                  IsReadOnly="True"
                                  CanUserAddRows="False"
                                  CanUserDeleteRows="False"
                                  HeadersVisibility="Column"
                                  Height="180">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Date" Binding="{Binding Date, StringFormat=yyyy-MM-dd HH:mm}" Width="130"/>
                                <DataGridTextColumn Header="Type" Binding="{Binding Type}" Width="70"/>
                                <DataGridTextColumn Header="Currency" Binding="{Binding Currency}" Width="80"/>
                                <DataGridTextColumn Header="Amount" Binding="{Binding Amount, StringFormat=N2}" Width="90"/>
                                <DataGridTextColumn Header="Rate" Binding="{Binding Rate, StringFormat=N4}" Width="90"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>
        </TabControl>

        <Border Grid.Row="1" Background="#EEEEEE" BorderBrush="#CCCCCC" BorderThickness="0,1,0,0" Padding="10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2*"/>
                    <ColumnDefinition Width="3*"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                    <TextBlock x:Name="UserStatusTextBlock" Text="Status: Not Logged In" Foreground="Gray" FontWeight="Bold"/>
                    <TextBlock x:Name="GlobalErrorTextBlock" Text="" Foreground="Red" FontSize="11" TextWrapping="Wrap" Margin="0,2,0,0"/>
                </StackPanel>
                <TextBlock x:Name="BalancesTextBlock" Grid.Column="1" FontFamily="Consolas" FontSize="12" HorizontalAlignment="Right" TextAlignment="Right" Text="Balances: Account Inactive"/>
            </Grid>
        </Border>
    </Grid>
</Window>