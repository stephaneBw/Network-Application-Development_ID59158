<Window x:Class="ExchangeOffice.Client.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Exchange Office - Lab 9" Height="450" Width="400" WindowStartupLocation="CenterScreen">
    <ScrollViewer>
        <StackPanel Margin="20">
            <TextBlock Text="--- User Registration (Lab 9) ---" FontSize="14" FontWeight="Bold" Foreground="#2196F3"/>

            <TextBlock Text="Username:" Margin="0,10,0,0"/>
            <TextBox x:Name="UsernameTextBox" Margin="0,5,0,0" Padding="4"/>

            <TextBlock Text="Password:" Margin="0,10,0,0"/>
            <PasswordBox x:Name="PasswordBox" Margin="0,5,0,15" Padding="4"/>

            <Button Content="Register Account" Height="30" FontWeight="Bold" Background="#2196F3" Foreground="White" Click="RegisterButton_Click"/>

            <TextBlock x:Name="UserStatusTextBlock" Margin="0,10,0,15" Text="Status: Not logged in" Foreground="Gray" FontStyle="Italic"/>

            <Separator Margin="0,10,0,20"/>

            <TextBlock Text="--- Live Market Rates (Lab 8) ---" FontSize="14" FontWeight="Bold" Foreground="#4CAF50"/>

            <TextBlock Text="Currency code (e.g. USD, EUR, GBP):" Margin="0,10,0,0" />
            <TextBox x:Name="CurrencyTextBox" Margin="0,5,0,10" Text="USD" Padding="4"/>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Button Content="Get Current Rate" Width="140" Height="30" Click="GetRateButton_Click"/>
                <TextBlock x:Name="RateTextBlock" Grid.Column="1" Margin="15,6,0,0" FontSize="13" FontWeight="Bold" VerticalAlignment="Center"/>
            </Grid>
        </StackPanel>
    </ScrollViewer>
</Window>